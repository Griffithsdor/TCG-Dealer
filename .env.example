# Copia a .env y rellena. NUNCA commitees .env con valores reales.

# --- Base de datos (local dev) ---
DATABASE_URL=postgresql://tcg:tcg@localhost:5432/tcg

# --- API keys de proveedores de precios ---
# En AWS estas viven en Secrets Manager; en local, aquí.
TCGAPI_KEY=            # tcgapi.dev (fuente unificada OP + Pokémon)
POKEMONTCG_API_KEY=    # pokemontcg.io / Scrydex
PRICECHARTING_TOKEN=   # graded vs ungraded
EBAY_CLIENT_ID=        # eBay Browse API
EBAY_CLIENT_SECRET=

# --- App ---
ENV=local
LOG_LEVEL=INFO
